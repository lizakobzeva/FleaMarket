# Переменные для docker-compose.prod.yml
# Секреты Gitea (Settings → Actions → Secrets):
#   RUNNER_TOKEN      — обязательно (токен с правом package)
#   SECRET_KEY        — ключ JWT для auth-service
#   POSTGRES_USER     — опционально (по умолчанию fleauser)
#   POSTGRES_PASSWORD — опционально (по умолчанию fleapass)

REGISTRY_PREFIX=git.klsh.ru/team30/fleamarket
IMAGE_TAG=latest

POSTGRES_USER=fleauser
POSTGRES_PASSWORD=fleapass
SECRET_KEY=your-production-secret-key-min-32-chars

# Порты на сервере после деплоя:
#   auth-service      → 8000  (https://teamN.klsh.ru)
#   products-service  → 8002
#   chat-service      → 8003
#   orders-service    → 8004
#   rating-service    → 8005
